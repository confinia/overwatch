{
  "uid": "api-access",
  "title": "API Access (Ops)",
  "description": "The public /v1 product API: traffic, latency, consumers, countries, keys. Metering view — this is what pricing reads at the monetization review.",
  "tags": [
    "ops",
    "api"
  ],
  "timezone": "utc",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": {
    "from": "now-24h",
    "to": "now"
  },
  "panels": [
    {
      "id": 1,
      "title": "/v1 requests / min, by route",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "promops"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 0
      },
      "targets": [
        {
          "expr": "sum by (route) (rate(ovw_api_requests_total[$__rate_interval])) * 60",
          "legendFormat": "{{route}}"
        }
      ]
    },
    {
      "id": 2,
      "title": "/v1 latency p50 / p95 (ms)",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "promops"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 0
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (le) (rate(ovw_duration_milliseconds_bucket{span_name=~\"(GET|POST) /v1.*\"}[$__rate_interval])))",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(ovw_duration_milliseconds_bucket{span_name=~\"(GET|POST) /v1.*\"}[$__rate_interval])))",
          "legendFormat": "p95"
        }
      ]
    },
    {
      "id": 3,
      "title": "HTTP status mix (429 = rate limit, 401 = key gate)",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "promops"
      },
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 0,
        "y": 8
      },
      "targets": [
        {
          "expr": "sum by (status) (rate(ovw_api_requests_total[$__rate_interval])) * 60",
          "legendFormat": "{{status}}"
        }
      ]
    },
    {
      "id": 4,
      "title": "Keyed vs anonymous requests / min",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "promops"
      },
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 8,
        "y": 8
      },
      "targets": [
        {
          "expr": "sum by (keyed) (rate(ovw_api_requests_total[$__rate_interval])) * 60",
          "legendFormat": "keyed={{keyed}}"
        }
      ]
    },
    {
      "id": 5,
      "title": "Consumer kind (direct API vs our UIs)",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "promops"
      },
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 16,
        "y": 8
      },
      "targets": [
        {
          "expr": "sum by (client) (rate(ovw_api_requests_total[$__rate_interval])) * 60",
          "legendFormat": "{{client}}"
        }
      ]
    },
    {
      "id": 6,
      "title": "Requests by country (range)",
      "type": "piechart",
      "datasource": {
        "type": "prometheus",
        "uid": "promops"
      },
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 0,
        "y": 16
      },
      "targets": [
        {
          "expr": "topk(15, sum by (country) (increase(ovw_api_requests_total[$__range])))",
          "legendFormat": "{{country}}",
          "instant": true
        }
      ]
    },
    {
      "id": 7,
      "title": "Unique visitors by country (range, all HTTP surfaces of /v1)",
      "type": "bargauge",
      "datasource": {
        "type": "postgres",
        "uid": "orbitcache"
      },
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 8,
        "y": 16
      },
      "targets": [
        {
          "format": "table",
          "rawSql": "SELECT country, count(DISTINCT client_hash) AS visitors FROM visitor_daily WHERE $__timeFilter(day) GROUP BY country ORDER BY visitors DESC LIMIT 15"
        }
      ],
      "options": {
        "displayMode": "gradient",
        "orientation": "horizontal",
        "reduceOptions": {
          "values": true,
          "fields": "/^visitors$/"
        }
      }
    },
    {
      "id": 8,
      "title": "Top API keys (range) — each key is a person we can talk to",
      "type": "table",
      "datasource": {
        "type": "postgres",
        "uid": "orbitcache"
      },
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 16,
        "y": 16
      },
      "targets": [
        {
          "format": "table",
          "rawSql": "SELECT left(k.key::text, 8) AS key, k.email, k.note, min(u.day) AS first_seen, sum(u.requests) AS requests FROM api_usage u JOIN api_key k USING (key) WHERE $__timeFilter(u.day) GROUP BY 1, 2, 3 ORDER BY requests DESC LIMIT 20"
        }
      ]
    }
  ]
}
