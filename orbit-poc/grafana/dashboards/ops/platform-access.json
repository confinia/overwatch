{
  "uid": "platform-access",
  "title": "Platform Access (Ops)",
  "tags": [
    "ops"
  ],
  "timezone": "utc",
  "schemaVersion": 39,
  "version": 4,
  "refresh": "30s",
  "time": {
    "from": "now-24h",
    "to": "now"
  },
  "panels": [
    {
      "id": 1,
      "title": "API requests / min, by route",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "promops"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 0
      },
      "targets": [
        {
          "expr": "sum by (span_name) (rate(ovw_calls_total[$__rate_interval])) * 60",
          "legendFormat": "{{span_name}}"
        }
      ]
    },
    {
      "id": 2,
      "title": "API latency p95, by route",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "promops"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 0
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ms"
        }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le, span_name) (rate(ovw_duration_milliseconds_bucket[$__rate_interval])))",
          "legendFormat": "{{span_name}}"
        }
      ]
    },
    {
      "id": 3,
      "title": "API errors / min",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "promops"
      },
      "gridPos": {
        "h": 7,
        "w": 8,
        "x": 0,
        "y": 8
      },
      "targets": [
        {
          "expr": "sum(rate(ovw_calls_total{status_code=\"STATUS_CODE_ERROR\"}[$__rate_interval])) * 60",
          "legendFormat": "errors"
        }
      ]
    },
    {
      "id": 4,
      "title": "Grafana traffic (embeds, queries) / min, by handler",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "promops"
      },
      "gridPos": {
        "h": 7,
        "w": 16,
        "x": 8,
        "y": 8
      },
      "targets": [
        {
          "expr": "topk(8, sum by (handler) (rate(grafana_http_request_duration_seconds_count[$__rate_interval])) * 60)",
          "legendFormat": "{{handler}}"
        }
      ]
    },
    {
      "id": 5,
      "title": "HTTP status mix (web API)",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "promops"
      },
      "gridPos": {
        "h": 7,
        "w": 8,
        "x": 0,
        "y": 15
      },
      "targets": [
        {
          "expr": "sum by (http_status_code) (rate(ovw_calls_total[$__rate_interval])) * 60",
          "legendFormat": "{{http_status_code}}"
        }
      ]
    },
    {
      "id": 7,
      "title": "Frontend events / hour (load, select, search)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "promops" },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 22 },
      "targets": [
        {
          "expr": "sum by (span_name) (rate(ovw_calls_total{span_name=~\"ui\\\\..*\"}[$__rate_interval])) * 3600",
          "legendFormat": "{{span_name}}"
        }
      ]
    },
    {
      "id": 8,
      "title": "Most-inspected satellites (selections in range)",
      "type": "bargauge",
      "datasource": { "type": "prometheus", "uid": "promops" },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 22 },
      "options": { "orientation": "horizontal", "displayMode": "gradient",
                   "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        {
          "expr": "topk(10, sum by (sat_norad) (increase(ovw_calls_total{span_name=\"ui.select\"}[$__range])))",
          "legendFormat": "NORAD {{sat_norad}}",
          "instant": true
        }
      ]
    },
    {
      "id": 9,
      "title": "Traffic origin (direct vs GitHub-Pages mirror)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "promops" },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 22 },
      "targets": [
        {
          "expr": "sum by (origin) (rate(ovw_calls_total{span_name=\"ui.load\"}[$__rate_interval])) * 3600",
          "legendFormat": "{{origin}}"
        }
      ]
    },
    {
      "id": 10,
      "title": "Estimated concurrent viewers (satellites poll = 4/min per tab)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "promops" },
      "gridPos": { "h": 7, "w": 24, "x": 0, "y": 30 },
      "targets": [
        {
          "expr": "sum(rate(ovw_calls_total{span_name=~\".*api/satellites.*\"}[5m])) * 15",
          "legendFormat": "open tabs (est.)"
        }
      ]
    },
    {
      "id": 6,
      "title": "Grafana in-flight requests",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "promops"
      },
      "gridPos": {
        "h": 7,
        "w": 16,
        "x": 8,
        "y": 15
      },
      "targets": [
        {
          "expr": "grafana_http_request_in_flight",
          "legendFormat": "in flight"
        }
      ]
    }
  ]
}
