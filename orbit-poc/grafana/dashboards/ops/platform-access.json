{
  "uid": "platform-access",
  "title": "Platform Access (Ops)",
  "tags": [
    "ops"
  ],
  "timezone": "utc",
  "schemaVersion": 39,
  "version": 3,
  "refresh": "30s",
  "time": {
    "from": "now-24h",
    "to": "now"
  },
  "panels": [
    {
      "id": 1,
      "title": "API requests / min, by route",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "promops"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 0
      },
      "targets": [
        {
          "expr": "sum by (span_name) (rate(ovw_calls_total[$__rate_interval])) * 60",
          "legendFormat": "{{span_name}}"
        }
      ]
    },
    {
      "id": 2,
      "title": "API latency p95, by route",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "promops"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 0
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ms"
        }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le, span_name) (rate(ovw_duration_milliseconds_bucket[$__rate_interval])))",
          "legendFormat": "{{span_name}}"
        }
      ]
    },
    {
      "id": 3,
      "title": "API errors / min",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "promops"
      },
      "gridPos": {
        "h": 7,
        "w": 8,
        "x": 0,
        "y": 8
      },
      "targets": [
        {
          "expr": "sum(rate(ovw_calls_total{status_code=\"STATUS_CODE_ERROR\"}[$__rate_interval])) * 60",
          "legendFormat": "errors"
        }
      ]
    },
    {
      "id": 4,
      "title": "Grafana traffic (embeds, queries) / min, by handler",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "promops"
      },
      "gridPos": {
        "h": 7,
        "w": 16,
        "x": 8,
        "y": 8
      },
      "targets": [
        {
          "expr": "topk(8, sum by (handler) (rate(grafana_http_request_duration_seconds_count[$__rate_interval])) * 60)",
          "legendFormat": "{{handler}}"
        }
      ]
    },
    {
      "id": 5,
      "title": "HTTP status mix (web API)",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "promops"
      },
      "gridPos": {
        "h": 7,
        "w": 8,
        "x": 0,
        "y": 15
      },
      "targets": [
        {
          "expr": "sum by (http_status_code) (rate(ovw_calls_total[$__rate_interval])) * 60",
          "legendFormat": "{{http_status_code}}"
        }
      ]
    },
    {
      "id": 6,
      "title": "Grafana in-flight requests",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "promops"
      },
      "gridPos": {
        "h": 7,
        "w": 16,
        "x": 8,
        "y": 15
      },
      "targets": [
        {
          "expr": "grafana_http_request_in_flight",
          "legendFormat": "in flight"
        }
      ]
    }
  ]
}
