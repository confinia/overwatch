# Copy to .env before `podman-compose up` (compose references it via env_file).
# Never commit .env.

# Free SatNOGS API key — enables the telemetry dashboards.
# Leave empty and the map + orbit tracks still work fully.
SATNOGS_TOKEN=

# Grafana admin password (anonymous viewers stay read-only; this protects
# the admin account). Generate one: openssl rand -base64 24
GF_SECURITY_ADMIN_PASSWORD=change-me

# Salt for unique-visitor hashing in the public API (never the IP itself —
# a salted daily digest). Empty = unique-visitor counting disabled.
# Generate one: openssl rand -base64 24
VISITOR_SALT_SECRET=
